{
  "name": "lora-training-dashboard",
  "version": "1.0.0-beta.1",
  "description": "Web interface for training and managing LoRA adapters",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "type-check": "tsc --noEmit",
    "electron:start": "electron dist/main.js",
    "electron:build": "webpack --mode development --config-name electron",
    "electron:dev": "npm run electron:build && concurrently \"npm run dev\" \"wait-on http://localhost:3005 && npm run electron:start\"",
    "electron:dist": "npm run build && npm run electron:build && npx electron-builder"
  },
  "build": {
    "appId": "com.lorastudio.app",
    "productName": "LoRA Studio",
    "directories": {
      "output": "dist/release"
    },
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!env/**/*",
          "!.venv/**/*",
          "!output/**/*",
          "!generated/**/*",
          "!datasets/**/*",
          "!__pycache__/**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LoRA Studio",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "react-dropzone": "^14.3.5",
    "lucide-react": "^0.460.0",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.9",
    "@babel/preset-typescript": "^7.26.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "style-loader": "^4.0.0",
    "typescript": "^5.7.2",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0",
    "electron": "^30.0.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "electron-builder": "^24.13.3"
  }
}
